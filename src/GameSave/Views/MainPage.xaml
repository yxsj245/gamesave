<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="GameSave.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:GameSave.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <Storyboard x:Name="ShowDetailsStoryboard">
            <DoubleAnimation Storyboard.TargetName="DetailsOverlay" 
                             Storyboard.TargetProperty="Opacity" 
                             To="1" Duration="0:0:0.25">
                 <DoubleAnimation.EasingFunction>
                     <ExponentialEase EasingMode="EaseOut" Exponent="4"/>
                 </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DetailsCardScale" 
                             Storyboard.TargetProperty="ScaleX" 
                             To="1" Duration="0:0:0.35">
                 <DoubleAnimation.EasingFunction>
                     <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                 </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DetailsCardScale" 
                             Storyboard.TargetProperty="ScaleY" 
                             To="1" Duration="0:0:0.35">
                 <DoubleAnimation.EasingFunction>
                     <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                 </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Name="HideDetailsStoryboard" Completed="HideDetailsStoryboard_Completed">
            <DoubleAnimation Storyboard.TargetName="DetailsOverlay" 
                             Storyboard.TargetProperty="Opacity" 
                             To="0" Duration="0:0:0.2">
                 <DoubleAnimation.EasingFunction>
                     <ExponentialEase EasingMode="EaseIn" Exponent="4"/>
                 </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DetailsCardScale" 
                             Storyboard.TargetProperty="ScaleX" 
                             To="0.9" Duration="0:0:0.2">
                 <DoubleAnimation.EasingFunction>
                     <ExponentialEase EasingMode="EaseIn" Exponent="6"/>
                 </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DetailsCardScale" 
                             Storyboard.TargetProperty="ScaleY" 
                             To="0.9" Duration="0:0:0.2">
                 <DoubleAnimation.EasingFunction>
                     <ExponentialEase EasingMode="EaseIn" Exponent="6"/>
                 </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid>
        <!-- 主导航栏 -->
        <NavigationView
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
            PaneDisplayMode="Left"
            OpenPaneLength="180">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="我的游戏" Tag="Home">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="云端" Tag="Cloud">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE753;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <!-- 底部状态指示灯，用于展示同步状态 -->
                <NavigationViewItem Content="同步就绪">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE895;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!-- 页面主内容区 -->
            <Grid Padding="16,0,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- 顶部功能区 -->
                    <RowDefinition Height="*" />
                    <!-- 内容区 -->
                </Grid.RowDefinitions>

                <!-- 顶端工具栏 -->
                <CommandBar DefaultLabelPosition="Right"
                            Background="Transparent"
                            Grid.Row="0" Margin="0,0,0,12">
                    <AppBarButton Label="添加游戏">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE710;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Label="一键备份">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE898;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>

                <!-- 中间内容：游戏卡片库 -->
                <GridView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.Games, Mode=OneWay}"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="GamesGridView_ItemClick">
                    <GridView.Resources>
                        <SolidColorBrush x:Key="GridViewItemBackgroundPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="GridViewItemBorderBrushPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="GridViewItemBackgroundPressed" Color="Transparent" />
                        <SolidColorBrush x:Key="GridViewItemBorderBrushPressed" Color="Transparent" />
                    </GridView.Resources>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="UseSystemFocusVisuals" Value="False" />
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemContainerTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True" />
                        </TransitionCollection>
                    </GridView.ItemContainerTransitions>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:Game">
                            <Border Margin="8" Width="220" Height="260"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="8"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    PointerEntered="GameCard_PointerEntered"
                                    PointerExited="GameCard_PointerExited"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </Border.RenderTransform>
                                <!-- 当用户悬停或点击时，增加一定的过渡动画 -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="180" /> <!-- 封面占位符高度 -->
                                        <RowDefinition Height="*" /> <!-- 文字区高度 -->
                                    </Grid.RowDefinitions>
                                    
                                    <!-- 封面占位 -->
                                    <Border Grid.Row="0" CornerRadius="8,8,0,0" Background="LightGray">
                                        <FontIcon Glyph="&#xE7FC;" FontSize="48" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    
                                    <!-- 游戏信息文本 -->
                                    <StackPanel Grid.Row="1" Padding="12" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}" 
                                                   FontWeight="Bold" 
                                                   FontSize="16" 
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind SaveFolderPath}" 
                                                   Foreground="DarkGray" 
                                                   FontSize="12" 
                                                   Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <!-- 游戏详情浮层 (Overlay) -->
                <!-- 如果 ViewModel.IsDetailsVisible 为 true，通过事件触发动画 -->
                <Grid x:Name="DetailsOverlay" Grid.Row="0" Grid.RowSpan="2" 
                      Background="#80000000" 
                      Visibility="Collapsed"
                      Opacity="0">
                      
                    <Border x:Name="DetailsCard"
                            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                            CornerRadius="12"
                            Margin="48"
                            Padding="32"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="DetailsCardScale" ScaleX="0.9" ScaleY="0.9" />
                        </Border.RenderTransform>
                            
                        <Grid DataContext="{x:Bind ViewModel, Mode=OneWay}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <!-- 浮层顶部：标题与关闭按钮 -->
                            <Grid Grid.Row="0" Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding SelectedGame.Name}" FontSize="32" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding SelectedGame.SaveFolderPath}" FontSize="14" Foreground="Gray" TextWrapping="Wrap"/>
                                </StackPanel>
                                
                                <Button Grid.Column="1" 
                                        VerticalAlignment="Top" 
                                        Click="CloseDetails_Click"
                                        Style="{StaticResource DefaultButtonStyle}">
                                    <FontIcon Glyph="&#xE711;" FontSize="16" />
                                </Button>
                            </Grid>
                            
                            <!-- 浮层内容：存档历史卡片列表 -->
                            <ListView Grid.Row="1" ItemsSource="{Binding CurrentSaves}" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16" />
                                                    <TextBlock Text="{Binding Description}" FontSize="14" Margin="0,4,0,0" TextWrapping="Wrap" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                        <TextBlock Text="{Binding DisplayBackupTime}" FontSize="12" Foreground="Gray" Margin="0,0,16,0"/>
                                                        <TextBlock Text="{Binding DisplayStorageType}" FontSize="12" Foreground="Gray"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                
                                                <!-- 右侧操作栏 -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="还原" Background="DodgerBlue" Foreground="White" Margin="0,0,8,0" />
                                                    <Button Margin="0,0,8,0" ToolTipService.ToolTip="上传至云端">
                                                        <FontIcon Glyph="&#xE898;" FontSize="14"/>
                                                    </Button>
                                                    <Button ToolTipService.ToolTip="删除">
                                                        <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="Red"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Page>
