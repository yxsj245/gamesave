<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="GameSave.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:GameSave.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- 详情浮层 - 显示动画 -->
        <Storyboard x:Name="ShowDetailsStoryboard">
            <DoubleAnimation Storyboard.TargetName="DetailsOverlay" 
                             Storyboard.TargetProperty="Opacity" 
                             To="1" Duration="0:0:0.25">
                 <DoubleAnimation.EasingFunction>
                     <ExponentialEase EasingMode="EaseOut" Exponent="4"/>
                 </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DetailsCardScale" 
                             Storyboard.TargetProperty="ScaleX" 
                             To="1" Duration="0:0:0.35">
                 <DoubleAnimation.EasingFunction>
                     <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                 </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DetailsCardScale" 
                             Storyboard.TargetProperty="ScaleY" 
                             To="1" Duration="0:0:0.35">
                 <DoubleAnimation.EasingFunction>
                     <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                 </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Name="HideDetailsStoryboard" Completed="HideDetailsStoryboard_Completed">
            <DoubleAnimation Storyboard.TargetName="DetailsOverlay" 
                             Storyboard.TargetProperty="Opacity" 
                             To="0" Duration="0:0:0.2">
                 <DoubleAnimation.EasingFunction>
                     <ExponentialEase EasingMode="EaseIn" Exponent="4"/>
                 </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DetailsCardScale" 
                             Storyboard.TargetProperty="ScaleX" 
                             To="0.9" Duration="0:0:0.2">
                 <DoubleAnimation.EasingFunction>
                     <ExponentialEase EasingMode="EaseIn" Exponent="6"/>
                 </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DetailsCardScale" 
                             Storyboard.TargetProperty="ScaleY" 
                             To="0.9" Duration="0:0:0.2">
                 <DoubleAnimation.EasingFunction>
                     <ExponentialEase EasingMode="EaseIn" Exponent="6"/>
                 </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid Padding="16,0,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 顶部功能区 -->
            <RowDefinition Height="*" /> <!-- 内容区 -->
        </Grid.RowDefinitions>

        <!-- 顶端工具栏 -->
        <CommandBar DefaultLabelPosition="Right"
                    Background="Transparent"
                    Grid.Row="0" Margin="0,0,0,12">
            <AppBarButton Label="添加游戏" Click="AddGame_Click">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE710;" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <!-- 空状态提示 -->
        <StackPanel Grid.Row="1" 
                    x:Name="EmptyStatePanel"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
            <FontIcon Glyph="&#xE7FC;" FontSize="64" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="还没有添加任何游戏" FontSize="18" Foreground="Gray" HorizontalAlignment="Center"/>
            <TextBlock Text="点击上方「添加游戏」开始管理你的存档" FontSize="14" Foreground="DarkGray" HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- 游戏卡片库 -->
        <GridView Grid.Row="1"
                  x:Name="GamesGrid"
                  ItemsSource="{x:Bind ViewModel.Games, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="GamesGridView_ItemClick">
            <GridView.Resources>
                <SolidColorBrush x:Key="GridViewItemBackgroundPointerOver" Color="Transparent" />
                <SolidColorBrush x:Key="GridViewItemBorderBrushPointerOver" Color="Transparent" />
                <SolidColorBrush x:Key="GridViewItemBackgroundPressed" Color="Transparent" />
                <SolidColorBrush x:Key="GridViewItemBorderBrushPressed" Color="Transparent" />
            </GridView.Resources>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="UseSystemFocusVisuals" Value="False" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemContainerTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition IsStaggeringEnabled="True" />
                </TransitionCollection>
            </GridView.ItemContainerTransitions>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:Game">
                    <Border Margin="8" Width="220" Height="260"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            PointerEntered="GameCard_PointerEntered"
                            PointerExited="GameCard_PointerExited"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="启动游戏" Click="ContextLaunch_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE768;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="手动备份" Click="ContextBackup_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE898;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="删除游戏" Click="ContextDelete_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE74D;" Foreground="Red"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Border.ContextFlyout>
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="180" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                
                                <!-- 封面占位 -->
                                <Border Grid.Row="0" CornerRadius="8,8,0,0" Background="LightGray">
                                    <FontIcon Glyph="&#xE7FC;" FontSize="48" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                
                                <!-- 游戏信息文本 -->
                                <StackPanel Grid.Row="1" Padding="12" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Name}" 
                                               FontWeight="Bold" 
                                               FontSize="16" 
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind DisplayAddedAt}" 
                                               Foreground="DarkGray" 
                                               FontSize="12" 
                                               Margin="0,4,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!-- 游戏详情浮层 (Overlay) -->
        <Grid x:Name="DetailsOverlay" Grid.Row="0" Grid.RowSpan="2" 
              Background="#80000000" 
              Visibility="Collapsed"
              Opacity="0">
              
            <Border x:Name="DetailsCard"
                    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                    CornerRadius="12"
                    Margin="48"
                    Padding="32"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="DetailsCardScale" ScaleX="0.9" ScaleY="0.9" />
                </Border.RenderTransform>
                    
                <Grid DataContext="{x:Bind ViewModel, Mode=OneWay}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <!-- 顶部：标题与操作按钮 -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding SelectedGame.Name}" FontSize="28" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedGame.SaveFolderPath}" FontSize="13" Foreground="Gray" TextWrapping="WrapWholeWords" MaxLines="2"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Spacing="8">
                            <!-- 启动游戏 -->
                            <Button Click="LaunchGame_Click"
                                    Style="{StaticResource AccentButtonStyle}"
                                    ToolTipService.ToolTip="启动游戏">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE768;" FontSize="14"/>
                                    <TextBlock Text="启动"/>
                                </StackPanel>
                            </Button>
                            <!-- 手动备份 -->
                            <Button Click="ManualBackup_Click"
                                    ToolTipService.ToolTip="手动备份当前存档">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE898;" FontSize="14"/>
                                    <TextBlock Text="备份"/>
                                </StackPanel>
                            </Button>
                            <!-- 删除游戏 -->
                            <Button Click="DeleteGame_Click"
                                    ToolTipService.ToolTip="删除游戏及所有存档">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="Red"/>
                            </Button>
                            <!-- 关闭 -->
                            <Button Click="CloseDetails_Click"
                                    Style="{StaticResource DefaultButtonStyle}">
                                <FontIcon Glyph="&#xE711;" FontSize="16" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- 进度条区域（备份/恢复时显示） -->
                    <StackPanel Grid.Row="1" 
                                Margin="0,0,0,12" 
                                Visibility="{Binding ActionProgressVisibility}" 
                                Spacing="4">
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="Gray" />
                        <ProgressBar IsIndeterminate="False" 
                                     Value="{Binding ActionProgress}" 
                                     HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- 存档列表标题 -->
                    <TextBlock Grid.Row="2" Text="存档列表" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    
                    <!-- 存档历史列表 -->
                    <ListView Grid.Row="3" ItemsSource="{Binding CurrentSaves}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10" Padding="16" 
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                        CornerRadius="8" 
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" />
                                                <!-- 存档标签 badge -->
                                                <Border Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}" 
                                                        CornerRadius="4" Padding="6,2" 
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsExitSave}">
                                                    <TextBlock Text="自动" FontSize="11" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="13" Margin="0,2,0,0" Foreground="Gray"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0" Spacing="16">
                                                <TextBlock Text="{Binding DisplayBackupTime}" FontSize="12" Foreground="Gray"/>
                                                <TextBlock Text="{Binding DisplaySize}" FontSize="12" Foreground="Gray"/>
                                                <TextBlock Text="{Binding DisplayTag}" FontSize="12" Foreground="Gray"/>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <!-- 右侧操作栏（仅手动存档可操作） -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                                            <Button Content="还原" 
                                                    Click="RestoreSave_Click"
                                                    IsEnabled="{Binding CanRestore}"
                                                    Style="{StaticResource AccentButtonStyle}" />
                                            <Button Click="DeleteSave_Click"
                                                    IsEnabled="{Binding CanDelete}"
                                                    ToolTipService.ToolTip="删除存档">
                                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="Red"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
